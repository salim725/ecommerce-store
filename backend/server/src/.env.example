# Copy this file to .env and fill in your own values

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/

PORT=3010

JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_EMAIL_SECRET=your-email-secret-here
JWT_EXPIRE=7d
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

EMAIL_FROM=your-email@gmail.com
EMAIL_APP_PASSWORD=your-google-app-password

NODE_ENV=development

CORS_CLIENTS=[{"origin":"http://localhost:3000","methods":["GET","POST","PUT","DELETE","PATCH"],"allowedHeaders":["Content-Type","Authorization"]},{"origin":"http://localhost:3001","methods":["GET","POST","PUT","DELETE","PATCH"],"allowedHeaders":["Content-Type","Authorization"]}]

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Optional — override default seed users (pnpm run seed:users)
# SEED_ADMIN_EMAIL=admin@crm.local
# SEED_ADMIN_PASSWORD=Admin123!
# SEED_CUSTOMER_EMAIL=customer@crm.local
# SEED_CUSTOMER_PASSWORD=Customer123!
